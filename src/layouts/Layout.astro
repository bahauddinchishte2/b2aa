---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import { getAllScholarships, getAllOpportunities, getAllResources, getAllBlogPosts } from '../lib/content';
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'scholarship' | 'opportunity' | 'resource';
  contentType?: 'blog' | 'scholarship' | 'opportunity' | 'resource';
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  nofollow?: boolean;
  hideTopSearch?: boolean;
  scholarship?: {
    deadline?: string;
    fundingType?: string;
    country?: string;
    levelOfStudy?: string;
    hostInstitution?: string;
    category?: string;
  };
  opportunity?: {
    deadline?: string;
    fundingType?: string;
    country?: string;
    levelOfStudy?: string;
    hostInstitution?: string;
    category?: string;
  };
  resource?: {
    area?: string;
    category?: string;
    lastUpdated?: string;
  };
}

const [allScholarships, allOpportunities, allResources, allBlogPosts] = await Promise.all([
  getAllScholarships(),
  getAllOpportunities(),
  getAllResources(),
  getAllBlogPosts(),
]);

const searchData = [
  ...allScholarships.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    slug: post.slug,
    type: 'scholarship'
  })),
  ...allOpportunities.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    slug: post.slug,
    type: 'opportunity'
  })),
  ...allResources.map(resource => ({
    title: resource.data.title,
    description: resource.data.description,
    area: resource.data.area,
    category: resource.data.category,
    tags: resource.data.tags,
    slug: resource.slug,
    type: 'resource'
  })),
  ...allBlogPosts.map(post => ({
    title: post.data.title,
    excerpt: post.data.excerpt,
    tags: post.data.tags,
    category: post.data.category,
    slug: post.slug,
    type: 'blog'
  }))
];

const { 
  title, 
  description = "Empowering Bangladeshi students with comprehensive information about international educational opportunities.",
  image = '/images/og-image.jpeg',
  canonical,
  type = 'website',
  contentType,
  publishDate,
  modifiedDate,
  author,
  keywords,
  noindex,
  nofollow,
  hideTopSearch = false,
  scholarship,
  opportunity,
  resource
} = Astro.props;

// Check if current page is homepage
const isHomePage = Astro.url.pathname === '/';

// Determine the title to display
const pageTitle = isHomePage ? 'Bangladesh to Abroad' : `${title} | Bangladesh to Abroad`;
---

<!doctype html>
<html lang="en-BD">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <link rel="dns-prefetch" href="https://images.pexels.com" />
    <link rel="dns-prefetch" href="https://api.dicebear.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#006A4E" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#006A4E" />
    <meta name="msapplication-TileColor" content="#006A4E" />
    <meta name="msapplication-TileImage" content="/favicon.svg" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Bangladesh to Abroad RSS Feed" href="/rss.xml" />

    <!-- Additional SEO Meta Tags -->
    <meta name="author" content="Bangladesh to Abroad" />
    <meta name="publisher" content="Bangladesh to Abroad" />
    <meta name="copyright" content="Bangladesh to Abroad" />
    <meta name="language" content="English" />
    <meta name="revisit-after" content="1 days" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta http-equiv="content-language" content="en" />

    <!-- Geo Tags for Bangladesh -->
    <meta name="geo.region" content="BD" />
    <meta name="geo.placename" content="Bangladesh" />

    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Lexend:wght@600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=Lexend:wght@600;700&display=swap" rel="stylesheet" /></noscript>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D6YBDD7R2Y"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-D6YBDD7R2Y', { send_page_view: true });
    </script>
    
    <!-- SEO Component -->
    <SEO
      title={pageTitle}
      description={description}
      image={image}
      canonical={canonical}
      type={type}
      contentType={contentType}
      publishDate={publishDate}
      modifiedDate={modifiedDate}
      author={author}
      keywords={keywords}
      noindex={noindex}
      nofollow={nofollow}
      scholarship={scholarship}
      opportunity={opportunity}
      resource={resource}
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <script define:vars={{ searchData }}>
      // Make search data available globally
      window.SEARCH_DATA = searchData;
    </script>
    <Header />
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <Footer />

    <!-- Google Translate -->
    <div id="google_translate_element" style="display:none;"></div>
    <button
      id="translate-btn"
      aria-label="Translate to Bangla"
      title="Translate to Bangla"
      class="fixed bottom-20 md:bottom-6 right-4 z-[80] h-11 px-3 bg-white border border-gray-200 rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 hover:shadow-xl transition-all duration-200 group translate-btn-expanded"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600 group-hover:text-primary-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
      </svg>
      <span class="translate-btn-label text-xs font-medium text-gray-600 group-hover:text-primary-600" id="translate-btn-text">বাংলা</span>
    </button>

    <script is:inline>
      function googleTranslateElementInit() {
        new google.translate.TranslateElement({
          pageLanguage: 'en',
          includedLanguages: 'bn,en',
          autoDisplay: false
        }, 'google_translate_element');
      }

      (function() {
        var btn = document.getElementById('translate-btn');
        var btnText = document.getElementById('translate-btn-text');
        var scriptLoaded = false;
        var isBangla = false;

        window.triggerTranslateToggle = function() {
          if (!scriptLoaded) {
            scriptLoaded = true;
            var s = document.createElement('script');
            s.src = '//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
            s.onload = function() {
              setTimeout(doTranslate, 1000);
            };
            document.body.appendChild(s);
          } else {
            doTranslate();
          }
        };

        btn.addEventListener('click', function() {
          window.triggerTranslateToggle();
        });

        function doTranslate() {
          var sel = document.querySelector('#google_translate_element select');
          if (sel) {
            var targetLang = isBangla ? 'en' : 'bn';
            sel.value = targetLang;
            sel.dispatchEvent(new Event('change'));
            isBangla = !isBangla;
            updateState();
          }
        }

        function updateState() {
          var html = document.documentElement;
          if (isBangla) {
            html.classList.add('translated-bn');
            btnText.textContent = 'English';
            btn.setAttribute('aria-label', 'Switch to English');
            btn.setAttribute('title', 'Switch to English');
          } else {
            html.classList.remove('translated-bn');
            btnText.textContent = 'বাংলা';
            btn.setAttribute('aria-label', 'Translate to Bangla');
            btn.setAttribute('title', 'Translate to Bangla');
          }
        }
      })();
    </script>

    <style is:global>
      .goog-te-banner-frame, .skiptranslate {
        display: none !important;
      }
      body {
        top: 0 !important;
      }

      .translated-bn body,
      .translated-bn *:not(code):not(pre):not(.notranslate) {
        font-family: 'Hind Siliguri', 'Inter', system-ui, sans-serif !important;
      }

      .translated-bn h1,
      .translated-bn h2 {
        font-family: 'Hind Siliguri', 'Lexend', system-ui, sans-serif !important;
      }

      .translated-bn .prose {
        line-height: 1.85 !important;
      }

      .translated-bn .prose p,
      .translated-bn .prose li {
        line-height: 1.9 !important;
      }

      .translated-bn .prose h2,
      .translated-bn .prose h3 {
        line-height: 1.4 !important;
      }

      .translate-btn-label {
        max-width: 0;
        opacity: 0;
        overflow: hidden;
        white-space: nowrap;
        transition: max-width 0.3s ease, opacity 0.2s ease, margin 0.3s ease;
        margin-left: 0;
      }

      .translate-btn-expanded .translate-btn-label {
        max-width: 120px;
        opacity: 1;
        margin-left: 6px;
      }
    </style>

    <!-- Theme switcher initialization script -->
    <script>
      import { defaultTheme, updateTheme } from '../config/theme';

      // Initialize theme on page load
      document.addEventListener('DOMContentLoaded', () => {
        // Try to load saved theme from localStorage
        const savedTheme = localStorage.getItem('site-theme');
        
        if (savedTheme) {
          try {
            const themeData = JSON.parse(savedTheme);
            updateTheme(themeData);
          } catch (e) {
            console.error('Error loading saved theme, using default', e);
            updateTheme(defaultTheme);
          }
        } else {
          // Use default theme
          updateTheme(defaultTheme);
        }
      });

      // Expose theme functions to global scope for easier access
      window.themeUtils = {
        updateTheme,
        
        // Function to change theme and save to localStorage
        changeTheme: (newTheme) => {
          updateTheme(newTheme);
          localStorage.setItem('site-theme', JSON.stringify(newTheme));
        },
        
        // Function to reset to default theme
        resetTheme: () => {
          updateTheme(defaultTheme);
          localStorage.setItem('site-theme', JSON.stringify(defaultTheme));
        }
      };
    </script>
  </body>
</html>

<style is:global>
  :root {
    --accent: 136, 58, 234;
    --accent-light: 224, 204, 250;
    --accent-dark: 49, 10, 101;
    --font-heading: 'Lexend', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-bangla: 'Hind Siliguri', system-ui, sans-serif;
    font-family: var(--font-body);
    --accent-gradient: linear-gradient(
      45deg,
      rgb(var(--accent)),
      rgb(var(--accent-light)) 30%,
      white 60%
    );
  }

  body {
    font-family: var(--font-body);
  }

  h1, h2 {
    font-family: var(--font-heading);
    font-weight: 700;
  }

  h3, h4, h5, h6 {
    font-family: var(--font-body);
    font-weight: 600;
  }

  button, .btn, input, select, textarea {
    font-family: var(--font-body);
  }

  /* Add padding at the bottom for mobile devices to account for the bottom navigation */
  @media (max-width: 768px) {
    body {
      padding-bottom: env(safe-area-inset-bottom, 0);
    }
  }
</style>