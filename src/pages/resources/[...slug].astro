---
import { getAllResources, getResourceContent } from '../../lib/content';
import ResourceBlog from '../../layouts/ResourceBlog.astro';
import PortableText from '../../components/PortableText.astro';

export async function getStaticPaths() {
  const resources = await getAllResources();
  return resources.map(resource => ({
    params: { slug: resource.slug },
    props: { slug: resource.slug },
  }));
}

const { slug } = Astro.props;
const resource = await getResourceContent(slug);

if (!resource) {
  return Astro.redirect('/resources');
}

let Content: any = null;
if (resource.source === 'mdx' && resource.render) {
  const rendered = await resource.render();
  Content = rendered.Content;
}
---

<ResourceBlog frontmatter={resource.data}>
  {resource.source === 'sanity' && resource.sanityBody ? (
    <PortableText value={resource.sanityBody} />
  ) : Content ? (
    <Content />
  ) : null}
</ResourceBlog>
