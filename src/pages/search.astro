---
import Layout from '../layouts/Layout.astro';
import { getAllScholarships, getAllOpportunities, getAllResources, getAllBlogPosts } from '../lib/content';

const [allScholarships, allOpportunities, allResources, allBlogPosts] = await Promise.all([
  getAllScholarships(),
  getAllOpportunities(),
  getAllResources(),
  getAllBlogPosts(),
]);

const searchData = [
  ...allScholarships.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    deadline: post.data.deadline,
    slug: post.slug,
    type: 'scholarship',
  })),
  ...allOpportunities.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    deadline: post.data.deadline,
    slug: post.slug,
    type: 'opportunity',
  })),
  ...allResources.map(resource => ({
    title: resource.data.title,
    description: resource.data.description,
    area: resource.data.area,
    category: resource.data.category,
    tags: resource.data.tags,
    lastUpdated: resource.data.lastUpdated,
    slug: resource.slug,
    type: 'resource',
  })),
  ...allBlogPosts.map(post => ({
    title: post.data.title,
    excerpt: post.data.excerpt,
    category: post.data.category,
    tags: post.data.tags,
    slug: post.slug,
    type: 'blog',
  })),
];
---

<Layout
  title="Search Results"
  description="Search for scholarships, internships, fellowships, and resources."
  keywords={["search", "scholarships", "opportunities", "resources"]}
  hideTopSearch={true}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <h1 id="search-heading" class="text-2xl sm:text-3xl font-bold text-center mb-8">Search</h1>

    <div class="mb-10 max-w-3xl mx-auto relative">
      <form id="search-form" action="/search" method="get" class="flex">
        <div class="relative flex-grow">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
          </div>
          <input
            type="search"
            id="search-input"
            name="q"
            class="w-full pl-10 pr-4 py-3 text-base text-gray-900 bg-white border-2 border-gray-200 rounded-l-xl focus:outline-none focus:ring-2 focus:ring-blue-200/50 focus:border-blue-300 transition-all duration-300"
            placeholder="Search for scholarships, opportunities or resources..."
            autocomplete="off"
          />
        </div>
        <button
          type="submit"
          class="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white text-base font-medium rounded-r-xl hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200/50 focus:ring-offset-2 transition-all duration-300"
        >
          Search
        </button>
      </form>
      <div id="search-dropdown" class="absolute left-0 right-0 top-full mt-1 bg-white rounded-xl shadow-xl border border-gray-200 divide-y divide-gray-100 max-h-96 overflow-y-auto hidden z-50"></div>
    </div>

    <div id="search-results"></div>
  </div>
</Layout>

<script define:vars={{ searchData }}>
  window.__SEARCH_DATA__ = searchData;
</script>

<script>
  function initSearch() {
    const data = (window as any).__SEARCH_DATA__ || [];
    const input = document.getElementById('search-input') as HTMLInputElement;
    const heading = document.getElementById('search-heading')!;
    const resultsContainer = document.getElementById('search-results')!;
    const dropdown = document.getElementById('search-dropdown')!;
    const form = document.getElementById('search-form')!;

    if (!input || !heading || !resultsContainer) return;

    function matchText(text: string | undefined | null, query: string): boolean {
      if (!text) return false;
      const hay = String(text).toLowerCase();
      if (hay.includes(query)) return true;
      return query.split(/\s+/).every(w => hay.includes(w));
    }

    function filterItems(items: any[], query: string): any[] {
      if (!query) return [];
      const q = query.toLowerCase();
      return items.filter(item =>
        matchText(item.title, q) ||
        matchText(item.country, q) ||
        matchText(item.fundingType, q) ||
        matchText(item.levelOfStudy, q) ||
        matchText(item.description, q) ||
        matchText(item.excerpt, q) ||
        matchText(item.area, q) ||
        (item.tags && item.tags.some((t: string) => matchText(t, q)))
      );
    }

    function highlightMatch(text: string | undefined, query: string): string {
      if (!text || !query) return text || '';
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark class="bg-yellow-100 font-medium">$1</mark>');
    }

    function getItemUrl(item: any): string {
      switch (item.type) {
        case 'scholarship': return `/scholarships/${item.slug}`;
        case 'opportunity': return `/opportunities/${item.slug}`;
        case 'resource': return `/resources/${item.slug}`;
        case 'blog': return `/blog/${item.slug}`;
        default: return '#';
      }
    }

    function getTypeLabel(item: any): { label: string; cls: string } {
      switch (item.type) {
        case 'scholarship': return { label: 'Scholarship', cls: 'bg-green-100 text-green-700' };
        case 'opportunity': return { label: (item.category || '').includes('internship') ? 'Internship' : 'Fellowship', cls: 'bg-orange-100 text-orange-700' };
        case 'resource': return { label: 'Resource', cls: 'bg-blue-100 text-blue-700' };
        case 'blog': return { label: 'Blog', cls: 'bg-gray-100 text-gray-700' };
        default: return { label: item.type, cls: 'bg-gray-100 text-gray-600' };
      }
    }

    function formatDate(dateStr: string): string {
      if (!dateStr) return '';
      try {
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      } catch { return dateStr; }
    }

    function renderDropdown(query: string) {
      const hits = filterItems(data, query);
      if (!query) { dropdown.classList.add('hidden'); return; }
      if (hits.length === 0) {
        dropdown.innerHTML = `<div class="p-4 text-sm text-gray-500 text-center">No results found for "${query}"</div>`;
        dropdown.classList.remove('hidden');
        return;
      }
      const rows = hits.slice(0, 6).map(item => {
        const cfg = getTypeLabel(item);
        const meta = [item.country, item.levelOfStudy].filter(Boolean).join(' \u00b7 ');
        return `<a href="${getItemUrl(item)}" class="flex items-center justify-between gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
          <div><div class="text-sm font-medium text-gray-900">${item.title}</div>
          ${meta ? `<div class="text-xs text-gray-500 mt-0.5">${meta}</div>` : ''}</div>
          <span class="text-xs px-2 py-0.5 rounded-full flex-shrink-0 ${cfg.cls}">${cfg.label}</span></a>`;
      }).join('');
      dropdown.innerHTML = rows;
      dropdown.classList.remove('hidden');
    }

    function renderFullResults(query: string) {
      if (!query) {
        heading.textContent = 'Search';
        resultsContainer.innerHTML = '';
        return;
      }

      heading.innerHTML = `Search Results for "${query}"`;
      const hits = filterItems(data, query);

      if (hits.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-10">
            <div class="text-6xl mb-4">&#128269;</div>
            <h2 class="text-2xl font-semibold text-gray-700 mb-2">No results found</h2>
            <p class="text-gray-500 max-w-lg mx-auto">
              We couldn't find any matches for "${query}". Try using different keywords or check your spelling.
            </p>
          </div>`;
        return;
      }

      const groups: Record<string, any[]> = { scholarship: [], opportunity: [], resource: [], blog: [] };
      hits.forEach(item => {
        if (groups[item.type]) groups[item.type].push(item);
      });

      let html = '<div class="space-y-10">';
      const today = new Date();

      if (groups.scholarship.length > 0) {
        html += `<section><h2 class="text-xl sm:text-2xl font-bold mb-4 pb-2 border-b">Scholarships <span class="text-gray-500 font-normal text-lg">(${groups.scholarship.length})</span></h2><div class="space-y-6">`;
        groups.scholarship.forEach(item => {
          const isOpen = item.deadline ? new Date(item.deadline) >= today : false;
          const catLabel = item.category === 'government-scholarship' ? 'Government Scholarship' : item.category === 'university-scholarship' ? 'University Scholarship' : '';
          const catCls = item.category === 'government-scholarship' ? 'bg-teal-100 text-teal-800' : 'bg-blue-100 text-blue-800';
          html += `<a href="/scholarships/${item.slug}" class="block bg-white p-5 rounded-lg shadow-md hover:shadow-lg transition-shadow border border-gray-100">
            <div class="mb-3 flex flex-wrap gap-2">
              <span class="inline-block px-3 py-1 rounded-full text-xs ${isOpen ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${isOpen ? 'Currently Open' : 'Closed'}</span>
              ${catLabel ? `<span class="inline-block px-3 py-1 ${catCls} rounded-full text-xs">${catLabel}</span>` : ''}
            </div>
            <h3 class="text-lg font-bold mb-2">${highlightMatch(item.title, query)}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
              <div class="flex items-center gap-1"><span class="text-gray-600">&#127758;</span> ${highlightMatch(item.country, query) || ''}</div>
              <div class="flex items-center gap-1"><span class="text-gray-600">&#127891;</span> ${highlightMatch(item.levelOfStudy, query) || ''}</div>
              ${item.fundingType ? `<div class="flex items-center gap-1"><span class="text-gray-600">&#128176;</span> ${highlightMatch(item.fundingType, query)}</div>` : ''}
              ${item.deadline ? `<div class="flex items-center gap-1"><span class="${isOpen ? 'text-green-600' : 'text-red-600'}">Deadline: ${formatDate(item.deadline)}</span></div>` : ''}
            </div>
            ${item.tags && item.tags.length > 0 ? `<div class="mt-3 flex flex-wrap gap-2">${item.tags.slice(0, 3).map((t: string) => `<span class="px-2 py-1 ${t.toLowerCase().includes(query.toLowerCase()) ? 'bg-yellow-100 font-medium' : 'bg-gray-100'} rounded-full text-xs">${t}</span>`).join('')}${item.tags.length > 3 ? `<span class="px-2 py-1 bg-gray-100 text-gray-800 rounded-full text-xs">+${item.tags.length - 3} more</span>` : ''}</div>` : ''}
          </a>`;
        });
        html += '</div></section>';
      }

      if (groups.opportunity.length > 0) {
        html += `<section><h2 class="text-xl sm:text-2xl font-bold mb-4 pb-2 border-b">Opportunities <span class="text-gray-500 font-normal text-lg">(${groups.opportunity.length})</span></h2><div class="space-y-6">`;
        groups.opportunity.forEach(item => {
          const isOpen = item.deadline ? new Date(item.deadline) >= today : false;
          const catLabel = item.category === 'internship' ? 'Internship' : item.category === 'fellowship' ? 'Fellowship' : '';
          const catCls = item.category === 'internship' ? 'bg-orange-100 text-orange-800' : 'bg-blue-100 text-blue-800';
          html += `<a href="/opportunities/${item.slug}" class="block bg-white p-5 rounded-lg shadow-md hover:shadow-lg transition-shadow border border-gray-100">
            <div class="mb-3 flex flex-wrap gap-2">
              <span class="inline-block px-3 py-1 rounded-full text-xs ${isOpen ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${isOpen ? 'Currently Open' : 'Closed'}</span>
              ${catLabel ? `<span class="inline-block px-3 py-1 ${catCls} rounded-full text-xs">${catLabel}</span>` : ''}
            </div>
            <h3 class="text-lg font-bold mb-2">${highlightMatch(item.title, query)}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
              <div class="flex items-center gap-1"><span class="text-gray-600">&#127758;</span> ${highlightMatch(item.country, query) || ''}</div>
              <div class="flex items-center gap-1"><span class="text-gray-600">&#127891;</span> ${highlightMatch(item.levelOfStudy, query) || ''}</div>
              ${item.fundingType ? `<div class="flex items-center gap-1"><span class="text-gray-600">&#128176;</span> ${highlightMatch(item.fundingType, query)}</div>` : ''}
              ${item.deadline ? `<div class="flex items-center gap-1"><span class="${isOpen ? 'text-green-600' : 'text-red-600'}">Deadline: ${formatDate(item.deadline)}</span></div>` : ''}
            </div>
            ${item.tags && item.tags.length > 0 ? `<div class="mt-3 flex flex-wrap gap-2">${item.tags.slice(0, 3).map((t: string) => `<span class="px-2 py-1 ${t.toLowerCase().includes(query.toLowerCase()) ? 'bg-yellow-100 font-medium' : 'bg-gray-100'} rounded-full text-xs">${t}</span>`).join('')}${item.tags.length > 3 ? `<span class="px-2 py-1 bg-gray-100 text-gray-800 rounded-full text-xs">+${item.tags.length - 3} more</span>` : ''}</div>` : ''}
          </a>`;
        });
        html += '</div></section>';
      }

      if (groups.resource.length > 0) {
        html += `<section><h2 class="text-xl sm:text-2xl font-bold mb-4 pb-2 border-b">Resources & Guides <span class="text-gray-500 font-normal text-lg">(${groups.resource.length})</span></h2><div class="grid gap-6 md:grid-cols-2">`;
        groups.resource.forEach(item => {
          const catDisplay = (item.category || '').split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
          html += `<a href="/resources/${item.slug}" class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow border border-gray-200 overflow-hidden group">
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-3">${highlightMatch(item.title, query)}</h3>
              <p class="text-gray-600 text-sm mb-4 line-clamp-2">${highlightMatch(item.description, query) || ''}</p>
              <div class="flex items-center justify-between">
                ${item.lastUpdated ? `<div class="text-sm text-gray-500">${formatDate(item.lastUpdated)}</div>` : '<div></div>'}
                <div class="flex flex-wrap gap-2">
                  ${item.area ? `<span class="px-2 py-1 bg-blue-50 text-blue-700 rounded-full text-xs">${item.area}</span>` : ''}
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">${catDisplay}</span>
                </div>
              </div>
            </div>
          </a>`;
        });
        html += '</div></section>';
      }

      if (groups.blog.length > 0) {
        html += `<section><h2 class="text-xl sm:text-2xl font-bold mb-4 pb-2 border-b">Blog Posts <span class="text-gray-500 font-normal text-lg">(${groups.blog.length})</span></h2><div class="space-y-6">`;
        groups.blog.forEach(item => {
          html += `<a href="/blog/${item.slug}" class="block bg-white p-5 rounded-lg shadow-md hover:shadow-lg transition-shadow border border-gray-100">
            <h3 class="text-lg font-bold mb-2">${highlightMatch(item.title, query)}</h3>
            ${item.excerpt ? `<p class="text-gray-600 text-sm mb-3 line-clamp-2">${highlightMatch(item.excerpt, query)}</p>` : ''}
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">Blog</span>
              ${item.tags && item.tags.length > 0 ? item.tags.slice(0, 3).map((t: string) => `<span class="px-2 py-1 ${t.toLowerCase().includes(query.toLowerCase()) ? 'bg-yellow-100 font-medium' : 'bg-gray-100'} rounded-full text-xs">${t}</span>`).join('') : ''}
            </div>
          </a>`;
        });
        html += '</div></section>';
      }

      html += '</div>';
      resultsContainer.innerHTML = html;
    }

    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q') || '';
    if (initialQuery) {
      input.value = initialQuery;
      renderFullResults(initialQuery);
    }

    input.addEventListener('input', () => {
      const q = input.value.trim();
      renderDropdown(q);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') dropdown.classList.add('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('#search-form, #search-dropdown')) {
        dropdown.classList.add('hidden');
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      dropdown.classList.add('hidden');
      const url = new URL(window.location.href);
      url.searchParams.set('q', q);
      window.history.pushState({}, '', url.toString());
      renderFullResults(q);
    });
  }

  document.addEventListener('DOMContentLoaded', initSearch);
  document.addEventListener('astro:after-swap', initSearch);
</script>
