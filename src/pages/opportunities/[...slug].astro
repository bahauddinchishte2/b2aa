---
import { getAllOpportunities, getOpportunityContent } from '../../lib/content';
import OpportunityPost from '../../layouts/OpportunityPost.astro';
import PortableText from '../../components/PortableText.astro';

export async function getStaticPaths() {
  const opportunities = await getAllOpportunities();
  return opportunities.map(opportunity => ({
    params: { slug: opportunity.slug },
    props: { slug: opportunity.slug },
  }));
}

const { slug } = Astro.props;
const opportunity = await getOpportunityContent(slug);

if (!opportunity) {
  return Astro.redirect('/opportunities/all');
}

let Content: any = null;
if (opportunity.source === 'mdx' && opportunity.render) {
  const rendered = await opportunity.render();
  Content = rendered.Content;
}
---

<OpportunityPost frontmatter={opportunity.data}>
  {opportunity.source === 'sanity' && opportunity.sanityBody ? (
    <PortableText value={opportunity.sanityBody} />
  ) : Content ? (
    <Content />
  ) : null}
</OpportunityPost>
