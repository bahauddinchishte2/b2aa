---
import { getAllScholarships, getScholarshipContent } from '../../lib/content';
import ScholarshipPost from '../../layouts/ScholarshipPost.astro';
import PortableText from '../../components/PortableText.astro';

export async function getStaticPaths() {
  const scholarships = await getAllScholarships();
  return scholarships.map(scholarship => ({
    params: { slug: scholarship.slug },
    props: { slug: scholarship.slug },
  }));
}

const { slug } = Astro.props;
const scholarship = await getScholarshipContent(slug);

if (!scholarship) {
  return Astro.redirect('/scholarships/all');
}

let Content: any = null;
if (scholarship.source === 'mdx' && scholarship.render) {
  const rendered = await scholarship.render();
  Content = rendered.Content;
}
---

<ScholarshipPost frontmatter={scholarship.data}>
  {scholarship.source === 'sanity' && scholarship.sanityBody ? (
    <PortableText value={scholarship.sanityBody} />
  ) : Content ? (
    <Content />
  ) : null}
</ScholarshipPost>
