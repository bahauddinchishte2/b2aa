---
import Layout from '../layouts/Layout.astro';
import DottedWorldMap from '../components/DottedWorldMap.astro';
import { getAllScholarships, getAllOpportunities, getAllResources, getAllBlogPosts } from '../lib/content';
import { format } from 'date-fns';

const [scholarships, opportunities, resources, blogPosts] = await Promise.all([
  getAllScholarships(),
  getAllOpportunities(),
  getAllResources(),
  getAllBlogPosts(),
]);

const totalCountries = [...new Set([
  ...scholarships.map(s => s.data.country),
  ...opportunities.map(o => o.data.country)
])].length;

const featuredScholarships = scholarships.slice(0, 3);

const searchData = [
  ...scholarships.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    slug: post.slug,
    type: 'scholarship'
  })),
  ...opportunities.map(post => ({
    title: post.data.title,
    country: post.data.country,
    fundingType: post.data.fundingType,
    levelOfStudy: post.data.levelOfStudy,
    category: post.data.category,
    tags: post.data.tags,
    slug: post.slug,
    type: 'opportunity'
  })),
  ...resources.map(resource => ({
    title: resource.data.title,
    description: resource.data.description,
    area: resource.data.area,
    category: resource.data.category,
    tags: resource.data.tags,
    slug: resource.slug,
    type: 'resource'
  })),
  ...blogPosts.map(post => ({
    title: post.data.title,
    excerpt: post.data.excerpt,
    tags: post.data.tags,
    category: post.data.category,
    slug: post.slug,
    type: 'blog'
  }))
];

const scholarshipImages: Record<string, string> = {
  'daad-scholarship-2024': 'https://images.pexels.com/photos/1595391/pexels-photo-1595391.jpeg?auto=compress&cs=tinysrgb&w=600',
  'erasmus-mundus-scholarship-2024': 'https://images.pexels.com/photos/672532/pexels-photo-672532.jpeg?auto=compress&cs=tinysrgb&w=600',
  'fulbright-scholarship-2024': 'https://images.pexels.com/photos/1454360/pexels-photo-1454360.jpeg?auto=compress&cs=tinysrgb&w=600',
  'oxford-university-scholarship-2024': 'https://images.pexels.com/photos/672532/pexels-photo-672532.jpeg?auto=compress&cs=tinysrgb&w=600',
  'stanford-university-scholarship-2024': 'https://images.pexels.com/photos/1454360/pexels-photo-1454360.jpeg?auto=compress&cs=tinysrgb&w=600',
  'korean-government-scholarship-2024': 'https://images.pexels.com/photos/373290/pexels-photo-373290.jpeg?auto=compress&cs=tinysrgb&w=600',
};

const defaultScholarshipImage = 'https://images.pexels.com/photos/267885/pexels-photo-267885.jpeg?auto=compress&cs=tinysrgb&w=600';

function getFundingBadgeStyle(fundingType: string) {
  const ft = (fundingType || '').toLowerCase();
  if (ft.includes('full')) return 'bg-green-100 text-green-700';
  if (ft.includes('partial')) return 'bg-yellow-100 text-yellow-700';
  return 'bg-blue-100 text-blue-700';
}

function getLevelBadgeStyle(level: string) {
  const l = (level || '').toLowerCase();
  if (l.includes('master')) return 'bg-blue-100 text-blue-700';
  if (l.includes('phd') || l.includes('doctor')) return 'bg-orange-100 text-orange-700';
  if (l.includes('bachelor')) return 'bg-teal-100 text-teal-700';
  return 'bg-gray-100 text-gray-600';
}

const countries = [
  { name: 'Germany', flag: '🇩🇪', count: scholarships.filter(s => s.data.country === 'Germany').length || 85 },
  { name: 'United States', flag: '🇺🇸', count: scholarships.filter(s => s.data.country === 'USA' || s.data.country === 'United States').length || 120 },
  { name: 'United Kingdom', flag: '🇬🇧', count: scholarships.filter(s => s.data.country === 'United Kingdom' || s.data.country === 'UK').length || 72 },
  { name: 'Canada', flag: '🇨🇦', count: scholarships.filter(s => s.data.country === 'Canada').length || 54 },
  { name: 'Australia', flag: '🇦🇺', count: scholarships.filter(s => s.data.country === 'Australia').length || 48 },
];
---

<Layout
  title="Bangladesh to Abroad - International Education Opportunities for Bangladeshi Students"
  description="Find scholarships, fellowships, internships and educational resources for Bangladeshi students looking to study and work abroad."
  keywords={["scholarships", "fellowships", "internships", "study abroad", "Bangladeshi students", "international education"]}
>

  <!-- ===== HERO ===== -->
  <section class="hero-section relative overflow-hidden">
    <div class="hero-bg absolute inset-0"></div>
    <div class="hero-dots absolute inset-0"></div>
    <div class="hero-map absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.18]">
      <div class="w-full max-w-5xl px-4">
        <DottedWorldMap />
      </div>
    </div>

    <div class="relative z-10 pt-16 pb-0">
      <div class="max-w-3xl mx-auto text-center px-4 sm:px-6">

        <!-- Trust badge -->
        <div class="inline-flex items-center gap-2 bg-white border border-blue-100 rounded-full px-4 py-1.5 mb-6 shadow-sm">
          <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-sm font-medium text-gray-600">Trusted by 10,000+ Students</span>
        </div>

        <h1 class="hero-title text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-4">
          <span class="block">Your Gateway to Global</span>
          <span class="block">Educational Opportunities</span>
        </h1>
        <p class="text-base sm:text-lg text-gray-500 mb-8 max-w-xl mx-auto">
          Discover verified scholarships, fellowships, and internships from around the world. Start your journey today.
        </p>

        <!-- Search bar -->
        <div class="max-w-xl mx-auto mb-5">
          <form id="hero-search-form" action="/search" method="get" class="flex items-center bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden pr-1.5 py-1.5 pl-4">
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="hero-search-input"
              name="q"
              type="text"
              placeholder="Search scholarships, countries, or fields..."
              class="flex-1 text-sm text-gray-700 placeholder-gray-400 bg-transparent outline-none py-1"
              autocomplete="off"
            />
            <button
              type="submit"
              id="hero-search-btn"
              class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors flex-shrink-0"
            >
              Search
            </button>
          </form>
        </div>

        <!-- Popular tags -->
        <div class="flex items-center justify-center flex-wrap gap-2 text-sm">
          <span class="text-gray-400 font-medium">Popular:</span>
          {['Germany', 'USA', 'UK', 'Fully Funded', 'Masters'].map(tag => (
            <a
              href={`/search?q=${encodeURIComponent(tag)}`}
              class="px-3 py-1 bg-white border border-gray-200 rounded-full text-gray-600 hover:border-blue-400 hover:text-blue-600 transition-colors shadow-sm"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>

      <!-- Hero bottom wave / cloud shape -->
      <div class="hero-wave mt-12">
        <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full block">
          <path fill="white" d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="bg-white py-10 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { value: '500+', label: 'Active Opportunities' },
          { value: `${totalCountries > 10 ? totalCountries : 50}+`, label: 'Countries Covered' },
          { value: '10K+', label: 'Community Members' },
          { value: '100%', label: 'Verified Listings' },
        ].map(stat => (
          <div>
            <div class="text-3xl sm:text-4xl font-bold text-blue-600">{stat.value}</div>
            <div class="text-sm text-gray-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FEATURED SCHOLARSHIPS ===== -->
  <section class="bg-white py-14 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Featured Scholarships</h2>
        <a href="/scholarships/all" class="text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center gap-1 transition-colors">
          View All
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredScholarships.map((s) => {
          const img = scholarshipImages[s.slug] || defaultScholarshipImage;
          const fundingLabel = s.data.fundingType || 'Funded';
          const levelLabel = s.data.levelOfStudy || 'All Levels';
          const deadlineStr = s.data.deadline ? format(new Date(s.data.deadline), 'MMM d, yyyy') : '';
          return (
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
              <div class="relative h-44 overflow-hidden">
                <img
                  src={img}
                  alt={s.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="400"
                  height="176"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <div class="flex items-center gap-2 mb-3 flex-wrap">
                  <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full ${getFundingBadgeStyle(fundingLabel)}`}>
                    {fundingLabel}
                  </span>
                  <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full ${getLevelBadgeStyle(levelLabel)}`}>
                    {levelLabel}
                  </span>
                </div>
                <h3 class="font-semibold text-gray-900 text-base mb-3 leading-snug">{s.data.title}</h3>
                <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    </svg>
                    {s.data.country}
                  </span>
                  {deadlineStr && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {deadlineStr}
                    </span>
                  )}
                </div>
                <a
                  href={`/scholarships/${s.slug}`}
                  class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-2.5 rounded-lg transition-colors"
                >
                  View Details
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="bg-gray-50 py-16 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">How It Works</h2>
        <p class="text-gray-500 text-base">Start your journey to studying abroad in just 3 simple steps</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
            title: 'Explore Opportunities',
            desc: 'Browse through our curated list of 500+ verified scholarships, fellowships, and internships from around the world.',
          },
          {
            num: '02',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />`,
            title: 'Save and Track',
            desc: "Bookmark your favorite opportunities and track application deadlines with our smart notification system.",
          },
          {
            num: '03',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />`,
            title: 'Apply with Confidence',
            desc: 'Access free resources, country guides, and test prep materials to submit winning applications.',
          },
        ].map(step => (
          <div class="bg-white rounded-2xl p-7 border border-gray-200 shadow-sm">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={step.icon}></svg>
              </div>
              <span class="text-2xl font-bold text-blue-100 leading-none">{step.num}</span>
            </div>
            <h3 class="text-base font-semibold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== BROWSE BY COUNTRY ===== -->
  <section class="bg-white py-14 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Browse by Country</h2>
        <a href="/scholarships/all" class="text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center gap-1 transition-colors">
          View All Countries
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {countries.map(c => (
          <a
            href={`/scholarships/all`}
            class="bg-white border border-gray-200 rounded-2xl p-5 text-center hover:border-blue-300 hover:shadow-md transition-all group"
          >
            <div class="text-4xl mb-3">{c.flag}</div>
            <div class="text-sm font-semibold text-gray-800 group-hover:text-blue-600 transition-colors mb-1">{c.name}</div>
            <div class="text-xs text-gray-400 mb-3">{c.count} Scholarships</div>
            <div class="text-xs text-blue-600 border border-blue-200 rounded-full py-1 px-3 inline-block group-hover:bg-blue-600 group-hover:text-white transition-colors">
              Explore
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SUCCESS STORIES ===== -->
  <section class="bg-gray-50 py-16 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Success Stories from Our Scholars</h2>
        <p class="text-gray-500 text-base">Real students who achieved their dreams through scholarships we helped them discover</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            name: 'Rafiq Ahmed',
            scholarship: 'DAAD',
            destination: 'TU Munich, 2024',
            destFlag: '🇩🇪',
            avatar: 'https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?auto=compress&cs=tinysrgb&w=100',
            quote: '"The DAAD scholarship covered everything - tuition, living costs, and even German classes. Bangladesh to Abroad\'s guides helped me navigate the entire process!"',
            badgeColor: 'bg-yellow-400',
          },
          {
            name: 'Fatima Khan',
            scholarship: 'Chevening',
            destination: 'LSE London, 2025',
            destFlag: '🇬🇧',
            avatar: 'https://images.pexels.com/photos/3769021/pexels-photo-3769021.jpeg?auto=compress&cs=tinysrgb&w=100',
            quote: '"I found the Chevening deadline reminder on this platform. The community mentors reviewed my essays and I got selected on my first attempt!"',
            badgeColor: 'bg-red-400',
          },
          {
            name: 'Tanvir Hasan',
            scholarship: 'Fulbright',
            destination: 'MIT, USA 2024',
            destFlag: '🇺🇸',
            avatar: 'https://images.pexels.com/photos/1222271/pexels-photo-1222271.jpeg?auto=compress&cs=tinysrgb&w=100',
            quote: '"The step-by-step Fulbright guide was a game changer. From the 10K+ community, I found alumni who mentored me through interviews!"',
            badgeColor: 'bg-blue-400',
          },
        ].map(story => (
          <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
            <div class="flex items-center gap-3 mb-4">
              <img
                src={story.avatar}
                alt={story.name}
                class="w-11 h-11 rounded-full object-cover flex-shrink-0"
                width="44"
                height="44"
                loading="lazy"
              />
              <div class="flex-1 min-w-0">
                <div class="font-semibold text-gray-900 text-sm">{story.name}</div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class={`text-xs text-white font-medium px-2 py-0.5 rounded-full ${story.badgeColor}`}>{story.scholarship}</span>
                  <span class="text-xs text-gray-500 flex items-center gap-1">{story.destFlag} {story.destination}</span>
                </div>
              </div>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed italic">{story.quote}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== JOIN COMMUNITY ===== -->
  <section class="bg-white py-14 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="bg-gray-50 border border-gray-200 rounded-2xl overflow-hidden">
        <div class="flex flex-col lg:flex-row">

          <!-- Left: image with overlay -->
          <div class="lg:w-5/12 relative min-h-[300px] lg:min-h-0">
            <img
              src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Students collaborating and discussing opportunities"
              class="absolute inset-0 w-full h-full object-cover"
              width="600"
              height="400"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gray-900/55"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-white p-8 text-center">
              <h3 class="text-2xl sm:text-3xl font-bold mb-3">Join Our Community</h3>
              <p class="text-white/85 text-sm sm:text-base max-w-xs">
                Connect with 10,000+ students and alumni from Bangladesh studying abroad
              </p>
              <div class="flex items-center gap-2.5 mt-5">
                <svg class="w-8 h-8" fill="white" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <span class="text-lg font-semibold">Facebook Group</span>
              </div>
            </div>
          </div>

          <!-- Right: benefits + CTA -->
          <div class="lg:w-7/12 p-8 sm:p-10 flex flex-col justify-center">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-7">Why Join Our Community?</h2>

            <div class="space-y-6 mb-8">
              {[
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
                  title: 'Get Real-Time Updates',
                  desc: 'Be the first to know about new scholarships and opportunities',
                },
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
                  title: 'Connect with Alumni',
                  desc: 'Network with students who have successfully studied abroad',
                },
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
                  title: 'Get Application Help',
                  desc: 'Ask questions and get guidance on your application process',
                },
              ].map(item => (
                <div class="flex items-start gap-4">
                  <div class="w-9 h-9 rounded-full bg-blue-50 border border-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-4.5 h-4.5 text-blue-600 w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon}></svg>
                  </div>
                  <div>
                    <div class="font-semibold text-gray-900 text-sm">{item.title}</div>
                    <div class="text-sm text-gray-500 mt-0.5">{item.desc}</div>
                  </div>
                </div>
              ))}
            </div>

            <a
              href="https://www.facebook.com/groups/bangladeshtoabroad"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2.5 w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm py-3 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
