---
const currentYear = new Date().getFullYear();

const contactInfo = {
  email: "bangladesh2abroad@gmail.com"
};

const opportunityLinks = [
  { name: "Scholarships", href: "/scholarships/all" },
  { name: "Fellowships", href: "/opportunities/fellowships" },
  { name: "Internships", href: "/opportunities/internships" },
  { name: "Research", href: "/opportunities/all" },
  { name: "Grants & Exchange Programs", href: "/opportunities/all" },
];

const resourceLinks = [
  { name: "Country Guides", href: "/resources" },
  { name: "Test Preparation", href: "/resources" },
  { name: "Application Tips", href: "/resources" },
  { name: "Success Stories", href: "/blog" },
  { name: "Blog", href: "/blog" },
];

const companyLinks = [
  { name: "About Us", href: "/about" },
  { name: "Contact", href: "/about" },
  { name: "Privacy", href: "/privacy" },
  { name: "Terms of Service", href: "/privacy" },
  { name: "FAQ", href: "/about" },
];

const socialLinks = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/Bangladeshtogoabroad",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`
  },
  {
    name: "Twitter",
    href: "https://twitter.com/bangladeshtoabroad",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
  },
  {
    name: "YouTube",
    href: "https://youtube.com/@bangladeshtoabroad",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`
  },
  {
    name: "Instagram",
    href: "https://www.instagram.com/bangladeshtoabroad",
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`
  },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 pb-10 border-b border-gray-800">

      <!-- Brand col -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2.5 mb-4">
          <img src="/images/logos/b2a-logo.png" alt="Bangladesh to Abroad logo" width="32" height="32" class="h-8 w-auto" />
          <span class="text-white font-semibold text-base">Bangladesh to Abroad</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Your trusted gateway to global educational opportunities. Verified scholarships, free resources, and a supportive community.
        </p>
        <div class="flex items-center gap-2.5 mt-5">
          {socialLinks.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="w-8 h-8 rounded-lg bg-gray-800 hover:bg-blue-600 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Opportunities -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Opportunities</h3>
        <ul class="space-y-2.5">
          {opportunityLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Resources</h3>
        <ul class="space-y-2.5">
          {resourceLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Company</h3>
        <ul class="space-y-2.5">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Stay Updated -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Stay Updated</h3>
        <p class="text-sm text-gray-400 mb-4 leading-relaxed">
          Get the latest scholarship alerts delivered to your inbox.
        </p>
        <form class="flex flex-col gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="Your email"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-blue-500 transition-colors"
          />
          <button
            type="submit"
            class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-2 rounded-lg transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-500">&copy; {currentYear} Bangladesh to Abroad. All rights reserved.</p>
      <p class="text-xs text-gray-500">Made with love for Bangladeshi students</p>
    </div>
  </div>
</footer>
