---
const resources = [
  {
    title: 'Country Guides',
    description: 'Comprehensive guides for 50+ countries covering visa requirements, cost of living, and university rankings.',
    link: '/resources/index',
    linkText: 'Browse Guides',
    iconBg: 'bg-blue-500',
    icon: `<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  },
  {
    title: 'Test Preparation',
    description: 'Free practice tests and study materials for IELTS, TOEFL, GRE, and GMAT with expert tips.',
    link: '/resources/index',
    linkText: 'Start Preparing',
    iconBg: 'bg-teal-500',
    icon: `<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M7 8h10M7 12h10M7 16h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    title: 'Application Tips',
    description: 'SOP writing guides, recommendation letter templates, and interview preparation tips from successful scholars.',
    link: '/resources/index',
    linkText: 'Get Tips',
    iconBg: 'bg-green-500',
    icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>`,
  },
  {
    title: 'Community Support',
    description: 'Connect with 10,000+ students and alumni. Get mentorship, essay reviews, and interview guidance.',
    link: 'https://www.facebook.com/groups/bangladeshtoabroad',
    linkText: 'Join Community',
    iconBg: 'bg-amber-500',
    icon: `<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  },
];
---

<section class="bg-gray-50 py-16 sm:py-20 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">Free Resources</h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">Everything you need to prepare winning applications</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {resources.map(r => (
        <div class="bg-white border border-gray-200 rounded-2xl p-7 flex flex-col hover:shadow-md transition-shadow">
          <div class={`w-12 h-12 ${r.iconBg} rounded-xl flex items-center justify-center mb-5 flex-shrink-0`}>
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" set:html={r.icon}></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">{r.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-5 flex-1">{r.description}</p>
          <a
            href={r.link}
            class="text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center gap-1.5 transition-colors"
            target={r.link.startsWith('http') ? '_blank' : undefined}
            rel={r.link.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {r.linkText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
