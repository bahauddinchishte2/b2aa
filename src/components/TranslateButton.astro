---
<button
  type="button"
  class="inline-translate-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-500 bg-gray-50 border border-gray-200 rounded-full hover:bg-primary-50 hover:text-primary-600 hover:border-primary-200 transition-all duration-200"
  aria-label="Translate this article"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
  </svg>
  <span class="inline-translate-text">বাংলায় পড়ুন</span>
</button>

<script is:inline>
  (function() {
    document.querySelectorAll('.inline-translate-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (typeof window.triggerTranslateToggle === 'function') {
          window.triggerTranslateToggle();
        }
      });
    });

    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.attributeName === 'class') {
          var isBn = document.documentElement.classList.contains('translated-bn');
          document.querySelectorAll('.inline-translate-text').forEach(function(span) {
            span.textContent = isBn ? 'Read in English' : 'বাংলায় পড়ুন';
          });
        }
      });
    });

    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  })();
</script>
